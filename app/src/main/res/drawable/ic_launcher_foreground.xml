<?xml version="1.0" encoding="utf-8"?>
<!--
    BodySense launcher icon foreground.
    A heartbeat / ECG pulse line with a heart at the peak — representing the BodySense brand.
    Designed for use on dark adaptive icon backgrounds.
    Also used as the monochrome icon (Android 13+).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer soft glow ring -->
    <path
        android:fillColor="#33FFFFFF"
        android:pathData="M54,28 A26,26 0 1,1 53.99,28 Z" />

    <!-- Heart shape centered in the icon -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M54,72
            C54,72 34,58 34,46
            C34,39.373 39.373,34 46,34
            C49.314,34 52.314,35.314 54.5,37.5
            C56.686,35.314 59.686,34 63,34
            C69.627,34 75,39.373 75,46
            C75,58 54,72 54,72 Z
        " />

    <!-- ECG / pulse line crossing beneath the heart -->
    <path
        android:strokeColor="#AAFFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="
            M20,74
            L34,74
