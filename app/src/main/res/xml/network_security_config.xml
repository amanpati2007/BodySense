<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Release builds: cleartext is NOT permitted to any domain (HTTPS only). -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
